{
	"editor.formatOnSave": false,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"prettier.useEditorConfig": true,
	"rust-analyzer.linkedProjects": [
		"./packages/scramjet/packages/core/rewriter/Cargo.toml"
	],
	"js/ts.preferences.includePackageJsonAutoImports": "off",
	"js/ts.suggest.autoImports": false,
	"js/ts.implicitProjectConfig.checkJs": true,
	"js/ts.validate.enabled": true,
	"explorer.excludeGitIgnore": false,
	"files.exclude": {
		"**/.git": false,
		"**/.svn": true,
		"**/.hg": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
		"**/CVS": true,
		"**/node_modules": false,
		"**/.circleci": false,
		"**/.compodocrc*": false,
		"**/.editorconfig": false,
		"**/.gitattributes": false,
		"**/.github": false,
		"**/.gitkeep": false,
		"**/.gitignore": false,
		"**/.npmrc": false,
		"**/.prettierignore": false,
		"**/.prettierrc*": false,
		"**/.scannerwork": false,
		"**/.eslint*": false,
		"**/.docker*": false,
		"**/docker": false,
		"**/.nvmrc": false,
		"**/.vscodeignore": false,
		"**/.vscode": false,
		"**/CHANGELOG.md": false,
		"**/README.md": false,
		"**/LICENSE.md": false,
		"**/angular.json": false,
		"**/workspace.json": false,
		"**/jest-mocks.ts": false,
		"**/jest.config.js": false,
		"**/jest.preset.js": false,
		"**/nx.json": false,
		"**/package-lock.json": false,
		"**/package.json": false,
		"**/sonar-project.properties": false,
		"**/tsconfig*": false,
		"**/tslint*": false,
		"**/babel*": false,
		"**/.babel*": false,
		"**/webpack*": false,
		"**/typings.d.ts": false,
		"**/*.yaml": false,
		"**/Makefile": false,
		"**/*.sh": false,
		"**/dist": false
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "vscode.typescript-language-features"
	},
	"search.exclude": {
		"external/playwright": true,
		"external/dreamlandjs": true
	}
}
